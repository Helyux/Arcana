{
  "manifest_version": 3,
  "name": "Arcana",
  "version": "1.0.1",
  "description": "Displays CS2 Float and Pattern Templates directly on Steam Market listings.",
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://steamcommunity.com/market/listings/730/*",
    "*://raw.githubusercontent.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "arcana@ankerlab.de",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://steamcommunity.com/market/listings/730/*"],
      "js": ["src/content/isolated.tsx"]
    },
    {
      "matches": ["*://steamcommunity.com/market/listings/730/*"],
      "js": ["src/content/main.ts"],
      "world": "MAIN"
    }
  ]
}
